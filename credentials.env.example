# Solar Hydroponic Monitor - Email Credentials
# Copy to /etc/solar-hydroponic/credentials.env and fill in your values.
# This file is loaded by systemd before starting the monitor services.
#
# Gmail setup:
#   1. Enable 2-factor authentication on your Google account
#   2. Go to: Google Account → Security → App Passwords
#   3. Create an App Password for "Mail"
#   4. Paste the 16-character password below (no spaces)

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=yoursixteencharap
SMTP_RECIPIENTS=recipient@gmail.com
